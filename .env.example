PORT=5000
NODE_ENV=development
MONGO_URI=mongodb://127.0.0.1:27017/foodsupply_b2b
MONGO_SERVER_SELECTION_TIMEOUT_MS=4000
BODY_LIMIT=8mb
CORS_ORIGINS=http://localhost:5000,http://127.0.0.1:5000,http://localhost,http://127.0.0.1
AUTH_SECRET=change-this-in-production
AUTH_TOKEN_TTL_SEC=604800
SEED_SYSTEM_USERS=true
SEED_BUYER_EMAIL=buyer@foodsupply.mn
SEED_BUYER_PASSWORD=Buyer@12345
SEED_BUYER_COMPANY=Мини маркет-01
SEED_BUYER_CONTACT_NAME=Buyer Owner
SEED_BUYER_PHONE=99001122
SEED_BUYER_ADDRESS=Улаанбаатар
SEED_SUPPLIER_EMAIL=supplier@foodsupply.mn
SEED_SUPPLIER_PASSWORD=Supplier@12345
SEED_SUPPLIER_COMPANY=Талх Трейд ХХК
SEED_SUPPLIER_CONTACT_NAME=Supplier Manager
SEED_SUPPLIER_PHONE=99112233
SEED_SUPPLIER_ADDRESS=Улаанбаатар
SEED_ADMIN_EMAIL=admin@foodsupply.mn
SEED_ADMIN_PASSWORD=Admin@12345
SEED_ADMIN_COMPANY=Систем Админ
SEED_ADMIN_CONTACT_NAME=System Admin
SEED_ADMIN_PHONE=00000000
SEED_ADMIN_ADDRESS=System
SEED_ADMIN2_EMAIL=admin@example.com
SEED_ADMIN2_PASSWORD=admin123
SEED_ADMIN2_COMPANY=Систем Админ
SEED_ADMIN2_CONTACT_NAME=System Admin
SEED_ADMIN2_PHONE=00000000
SEED_ADMIN2_ADDRESS=System
ALLOW_LEGACY_ROLE_HEADERS=false
API_RATE_LIMIT_WINDOW_MS=60000
API_RATE_LIMIT_MAX=240
AUTH_RATE_LIMIT_WINDOW_MS=60000
AUTH_RATE_LIMIT_MAX=20

# QPay integration
# QPAY_MODE=mock|live
QPAY_MODE=mock
QPAY_BASE_URL=https://merchant.qpay.mn/v2
QPAY_USERNAME=
QPAY_PASSWORD=
# Optional: if you already have a token, set this instead of username/password
QPAY_STATIC_TOKEN=
# Usually "Bearer"
QPAY_TOKEN_PREFIX=Bearer
QPAY_INVOICE_CODE=
QPAY_CALLBACK_BASE_URL=http://localhost:5000
QPAY_CALLBACK_SECRET=
QPAY_DEFAULT_RECEIVER_CODE=
QPAY_PLATFORM_RECEIVER_CODE=
# JSON map by supplier company name.
# Example: {"Талх Трейд ХХК":"supplier_receiver_code_1","Fresh Foods LLC":"supplier_receiver_code_2"}
QPAY_SUPPLIER_RECEIVER_MAP={}

# Был.mn integration (hosted invoice & checkout payments)
# Docs: https://byl.mn/docs/api/
# BYL_MODE=mock|live
BYL_MODE=mock
BYL_BASE_URL=https://byl.mn/api/v1
# Таны byl.mn дансны project ID (https://byl.mn/projects)
BYL_PROJECT_ID=
# Таны byl.mn API токен (https://byl.mn/user/api-tokens)
BYL_TOKEN=
# Usually "Bearer"
BYL_TOKEN_PREFIX=Bearer
BYL_CALLBACK_BASE_URL=http://localhost:5000
# Webhook signature secret (byl.mn вэб > webhook дэлгэрэнгүй > secret)
BYL_WEBHOOK_SECRET=
# Seed supplier bank account for testing
SEED_SUPPLIER_QPAY_RECEIVER_CODE=
SEED_SUPPLIER_BANK_ACCOUNT=
